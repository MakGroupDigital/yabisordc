rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Règles pour les publications
    match /posts/{postId} {
      // TEMPORAIRE : Permettre la lecture et l'écriture à tous (pour le développement)
      // REMPLACEZ par les règles ci-dessous en production
      allow read, write: if true;
      
      // RÈGLES DE PRODUCTION (décommentez après les tests) :
      // allow read: if request.auth != null;
      // allow create: if request.auth != null 
      //   && request.resource.data.authorId == request.auth.uid;
      // allow update: if request.auth != null 
      //   && resource.data.authorId == request.auth.uid;
      // allow delete: if request.auth != null 
      //   && resource.data.authorId == request.auth.uid;
    }
    
    // Règles pour les autres collections
    match /{document=**} {
      allow read, write: if true; // TEMPORAIRE pour le développement
    }
  }
}

